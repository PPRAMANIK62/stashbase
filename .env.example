# StashBase environment variables — reference
#
# NOTE: StashBase does NOT auto-load a .env file. These are plain shell
# environment variables; export them before launching, e.g.
#
#     STASHBASE_LOG=debug pnpm dev
#     STASHBASE_RECORDING_DEBUG=1 pnpm dev
#
# Everything here is OPTIONAL — the app runs with none of them set. This
# file just documents what exists. Copy a line into your shell / run
# config when you need it.
#
# (The server port is a CLI arg, not an env var: `--port 8090`.)


# ── Screen recording → text (Gemini video understanding) ────────────

# A screen recording (the rail's record button) is sent to Google's
# Gemini video-understanding API, which reads layout / reading order /
# on-screen actions natively, and writes a `recording-<ts>.md` note
# (summary + extracted content). The video itself is NOT stored.
# Without a key, recordings fall back to local frame-OCR (offline, free,
# but weaker on multi-column / dynamic screens).
#
# Privacy note: setting this UPLOADS recordings to Google — a departure
# from the otherwise local-first pipeline. Region screenshots and dropped
# images/PDFs/videos always stay local (RapidOCR).
# GEMINI_API_KEY=
# Model override (default: gemini-2.5-flash). Use gemini-2.5-pro for
# harder reasoning at higher cost.
# GEMINI_VIDEO_MODEL=gemini-2.5-flash


# ── Dev / debugging ──────────────────────────────────────────────────

# Log verbosity: debug | info | warn | error  (default: info)
# `debug` is noisy but shows daemon ops, conversion timing, etc.
STASHBASE_LOG=info

# Keep screen recordings for inspection instead of discarding them.
# When set, each recording leaves a bundle under
# ~/.stashbase/recording-debug/recording-<ts>/ :
#   source.webm  + frames/ (annotated OCR frames) + ocr_results.json
#   + ocr_unique_raw.json + the final recording-<ts>.md
# Use it to tune the frame sampling (fps / diff-threshold) and diagnose
# OCR misses. Default OFF — recordings are normally OCR'd then deleted.
# STASHBASE_RECORDING_DEBUG=1

# PDF text extractor: pymupdf (fast, default) | marker (slower, better
# layout/tables). Honoured by both server/pdf.ts and python/pdf_extract.py.
# STASHBASE_PDF_CONVERTER=pymupdf

# Dev only: proxy the renderer to the Vite dev server (hot reload) instead
# of serving the built bundle. `pnpm dev` sets these for you.
# STASHBASE_DEV_VITE=1
# VITE_PORT=5173


# ── Interpreter / binary overrides (advanced) ────────────────────────

# Python interpreter for the daemon + extractors. Auto-discovered
# (packaged runtime → python/.venv → python3); set only to force one.
# STASHBASE_PYTHON=/absolute/path/to/python


# ── Auto-set by the packaged app (don't set these by hand) ───────────
# Listed for reference only — the desktop build / MCP wrapper injects them.
#
#   STASHBASE_EXTRACT_BIN     packaged `stashbase-extract` binary
#   STASHBASE_DAEMON_BIN      packaged `stashbase-daemon` binary
#   STASHBASE_APP_ROOT        project/app root for the MCP wrapper
#   STASHBASE_RESOURCES_PATH  packaged resources dir
#   STASHBASE_WINDOW_ID       per-window id passed to the MCP server


# ── Release pipeline (only for `pnpm dist:brew`, usually via gh/CI) ──
# Not needed to run StashBase. `gh` typically supplies auth; the Homebrew
# tap push uses these. Leave unset for local dev.
#
#   GH_TOKEN / GITHUB_TOKEN        GitHub auth for the release + tap push
#   HOMEBREW_TAP                   e.g. liliu-z/homebrew-stashbase
#   HOMEBREW_CASK                  cask name (stashbase)
#   HOMEBREW_TAP_GIT_URL           tap repo git URL
#   HOMEBREW_GITHUB_API_TOKEN      token for the tap push
